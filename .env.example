# Server-only vars — never prefix with NEXT_PUBLIC_
PORTFOLIO_DB_PATH=./data/portfolio.db
PORTFOLIO_USER_ID=local

# Kite Connect app credentials (from developers.kite.trade).
# NEVER commit real values — this file is the template; put real ones in .env (gitignored).
KITE_API_KEY=your_api_key_here
KITE_API_SECRET=your_api_secret_here
# Must match the Redirect URL configured on your Kite Connect app:
KITE_REDIRECT_URL=http://127.0.0.1:3210/api/kite/callback

# --- OPTIONAL: fully unattended TOTP auto-login (UNOFFICIAL / grey-area) ---
# Setting all three enables scripted daily login (no browser click). This uses
# undocumented kite.zerodha.com auth endpoints and is against Zerodha's
# expectation of an interactive human login — use at your own risk. Leave blank
# to keep the documented one-click-a-day browser flow.
KITE_USER_ID=
KITE_PASSWORD=
KITE_TOTP_SECRET=
